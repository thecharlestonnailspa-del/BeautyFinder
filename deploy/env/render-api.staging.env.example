APP_ENV=staging
SEED_SAMPLE_DATA=false
DATABASE_URL=postgresql://staging_user:STAGING_PASSWORD@staging-postgres-host:5432/beauty_finder_staging?schema=public
REDIS_URL=redis://staging-redis-host:6379
JWT_SECRET=replace-with-a-long-random-staging-secret
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=https://staging-owner.example.com,https://staging-admin.example.com,https://staging-app.example.com
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
PAYMENT_TAX_RATE=0.08
OWNER_MEDIA_STORAGE_DRIVER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-supabase-service-role-key
OWNER_MEDIA_STORAGE_BUCKET=owner-media
OWNER_MEDIA_PUBLIC_BASE_URL=https://your-project-ref.supabase.co/storage/v1/object/public/owner-media
OWNER_MEDIA_STORAGE_PATH_PREFIX=staging
