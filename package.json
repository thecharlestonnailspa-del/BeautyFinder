{
  "name": "beauty-finder",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "frontend/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @beauty-finder/api",
    "dev:api": "npm run dev --workspace @beauty-finder/api",
    "dev:backend:api": "npm run dev --workspace @beauty-finder/api",
    "dev:backend:api-py": "backend/api-py/.venv/bin/python -m uvicorn --app-dir backend/api-py app.main:app --reload --host 127.0.0.1 --port 8001",
    "dev:backend:worker": "npm run dev --workspace @beauty-finder/worker",
    "dev:mobile": "npm run dev --workspace @beauty-finder/mobile-app --",
    "dev:worker": "npm run dev --workspace @beauty-finder/worker",
    "dev:owner": "npm run dev --workspace @beauty-finder/owner-dashboard",
    "dev:admin": "npm run dev --workspace @beauty-finder/admin-panel",
    "dev:frontend:mobile": "npm run dev --workspace @beauty-finder/mobile-app --",
    "dev:frontend:owner": "npm run dev --workspace @beauty-finder/owner-dashboard",
    "dev:frontend:admin": "npm run dev --workspace @beauty-finder/admin-panel",
    "start:api": "npm run start --workspace @beauty-finder/api",
    "start:backend:api": "npm run start --workspace @beauty-finder/api",
    "start:backend:api-py": "backend/api-py/.venv/bin/python -m uvicorn --app-dir backend/api-py app.main:app --host 0.0.0.0 --port 8001",
    "start:owner": "npm run start --workspace @beauty-finder/owner-dashboard",
    "start:admin": "npm run start --workspace @beauty-finder/admin-panel",
    "start:frontend:owner": "npm run start --workspace @beauty-finder/owner-dashboard",
    "start:frontend:admin": "npm run start --workspace @beauty-finder/admin-panel",
    "db:generate": "prisma generate",
    "db:push:local": "node prisma/check-env.js && prisma db push",
    "db:migrate:deploy": "node prisma/check-env.js && prisma migrate deploy",
    "db:migrate:resolve:baseline": "node prisma/check-env.js && prisma migrate resolve --applied 20260401213000_init",
    "db:seed:sample": "node prisma/check-env.js && node prisma/seed.js",
    "db:bootstrap": "node scripts/bootstrap-db.mjs",
    "db:setup": "npm run db:bootstrap",
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged",
    "test": "turbo run test",
    "test:api": "npm run test --workspace @beauty-finder/api",
    "test:api:watch": "npm run test:watch --workspace @beauty-finder/api",
    "check:backend:api-py": "PYTHONPYCACHEPREFIX=/tmp/codex-python-cache backend/api-py/.venv/bin/python -m compileall backend/api-py/app",
    "test:backend:api-py": "PYTHONPATH=backend/api-py backend/api-py/.venv/bin/python -m unittest discover -s backend/api-py/tests",
    "typecheck": "turbo run typecheck",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down --remove-orphans",
    "docker:reset": "docker compose down -v --remove-orphans",
    "prepare": "node scripts/setup-husky.mjs",
    "postinstall": "npm run db:generate"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": "eslint --fix",
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^6.8.2",
    "turbo": "^2.8.20",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
