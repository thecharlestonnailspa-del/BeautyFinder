generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum RoleName {
  CUSTOMER
  OWNER
  TECHNICIAN
  ADMIN
}

enum BusinessCategory {
  NAIL
  HAIR
}

enum BusinessStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  FLAGGED
}

enum PaymentMethod {
  CARD
  CASH
}

enum PaymentStatus {
  PAID
  REFUNDED
}

enum AdPlacement {
  HOMEPAGE_SPOTLIGHT
  CATEGORY_BOOST
  CITY_BOOST
}

enum ProfessionalAccountType {
  SALON_OWNER
  PRIVATE_TECHNICIAN
}

enum VerificationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PrivateTechnicianProfileStatus {
  DRAFT
  PUBLISHED
  SUSPENDED
}

enum PrivateTechnicianAdStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  passwordHash              String
  fullName                  String
  phone                     String?
  avatarUrl                 String?
  status                    UserStatus                 @default(ACTIVE)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  roles                     UserRole[]
  ownedBusinesses           Business[]                 @relation("BusinessOwner")
  customerAppointments      Appointment[]              @relation("AppointmentCustomer")
  ownerAppointments         Appointment[]              @relation("AppointmentOwner")
  staffAssignments          Staff[]                    @relation("StaffUser")
  sentMessages              Message[]                  @relation("MessageSender")
  reviews                   Review[]
  favorites                 Favorite[]
  businessPageViews         BusinessPageView[]         @relation("BusinessPageViewCustomer")
  notifications             Notification[]
  notificationPreference    NotificationPreference?
  professionalRegistration  ProfessionalRegistration?
  privateTechnicianProfile  PrivateTechnicianProfile?
  adminActions              AdminAction[]              @relation("AdminActor")
  adPricingUpdates          AdPricing[]                @relation("AdPricingUpdater")
  appointmentHistoryChanges AppointmentStatusHistory[]
  conversationParticipants  ConversationParticipant[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      RoleName
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model Business {
  id            String             @id @default(cuid())
  ownerUserId   String
  name          String
  description   String?
  category      BusinessCategory
  phone         String?
  email         String?
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  postalCode    String
  latitude      Decimal?
  longitude     Decimal?
  featuredOnHomepage Boolean          @default(false)
  homepageRank       Int              @default(999)
  heroImage     String?
  businessLogo  String?
  businessBanner String?
  ownerAvatarUrl String?
  videoUrl      String?
  promotionTitle String?
  promotionDescription String?
  promotionDiscountPercent Int?
  promotionCode String?
  promotionExpiresAt DateTime?
  rating        Float              @default(0)
  reviewCount   Int                @default(0)
  status        BusinessStatus     @default(DRAFT)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  owner         User               @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  images        BusinessImage[]
  services      Service[]
  staff         Staff[]
  availability  AvailabilitySlot[]
  appointments  Appointment[]
  conversations Conversation[]
  reviews       Review[]
  favorites     Favorite[]
  pageViews     BusinessPageView[]
  compliance    BusinessCompliance?

  @@index([ownerUserId])
  @@index([category, status])
  @@index([city, state])
  @@index([status, featuredOnHomepage, homepageRank])
}

model BusinessImage {
  id         String   @id @default(cuid())
  businessId String
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, sortOrder])
}

model Service {
  id              String             @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  availability    AvailabilitySlot[]

  @@index([businessId, isActive])
}

model Staff {
  id                String             @id @default(cuid())
  businessId        String
  userId            String?
  name              String
  title             String?
  avatarUrl         String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user              User?              @relation("StaffUser", fields: [userId], references: [id], onDelete: SetNull)
  availabilitySlots AvailabilitySlot[]
  appointments      Appointment[]

  @@unique([businessId, userId])
  @@index([businessId, isActive])
  @@index([userId])
}

model AvailabilitySlot {
  id         String   @id @default(cuid())
  businessId String
  serviceId  String?
  staffId    String?
  startTime  DateTime
  endTime    DateTime
  isBooked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staff      Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([businessId, startTime])
  @@index([serviceId, startTime])
  @@index([staffId, startTime])
}

model Appointment {
  id            String                     @id @default(cuid())
  customerId    String
  ownerId       String
  businessId    String
  serviceId     String
  staffId       String?
  status        AppointmentStatus          @default(PENDING)
  startTime     DateTime
  endTime       DateTime
  notes         String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  customer      User                       @relation("AppointmentCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  owner         User                       @relation("AppointmentOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  business      Business                   @relation(fields: [businessId], references: [id], onDelete: Restrict)
  service       Service                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff         Staff?                     @relation(fields: [staffId], references: [id], onDelete: SetNull)
  statusHistory AppointmentStatusHistory[]
  conversations Conversation[]
  review        Review?
  payment       Payment?

  @@index([customerId, startTime])
  @@index([ownerId, startTime])
  @@index([businessId, startTime])
  @@index([status, startTime])
}

model AppointmentStatusHistory {
  id              String             @id @default(cuid())
  appointmentId   String
  oldStatus       AppointmentStatus?
  newStatus       AppointmentStatus
  changedByUserId String
  createdAt       DateTime           @default(now())
  appointment     Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedBy       User               @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([appointmentId, createdAt])
}

model Conversation {
  id            String                    @id @default(cuid())
  businessId    String
  appointmentId String?
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime                  @default(now())
  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment   Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([businessId, createdAt])
  @@index([appointmentId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderUserId   String
  messageType    MessageType  @default(TEXT)
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model Review {
  id            String       @id @default(cuid())
  appointmentId String?      @unique
  businessId    String
  customerId    String
  rating        Int
  comment       String?
  customerAvatarUrl String?
  status        ReviewStatus @default(PUBLISHED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      User         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  images        ReviewImage[]

  @@index([businessId, status])
  @@index([customerId])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, sortOrder])
}

model BusinessPageView {
  id                  String   @id @default(cuid())
  businessId          String
  customerId          String
  selectedServiceId   String?
  selectedServiceName String?
  note                String?
  dwellSeconds        Int
  colorSignals        String?
  source              String   @default("mobile_salon_detail")
  createdAt           DateTime @default(now())
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer            User     @relation("BusinessPageViewCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([customerId, createdAt])
  @@index([selectedServiceId])
  @@map("CustomerBusinessPageView")
}

model Favorite {
  customerId String
  businessId String
  createdAt  DateTime @default(now())
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@id([customerId, businessId])
  @@index([businessId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  payload   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model NotificationPreference {
  userId            String   @id
  bookingCreated    Boolean  @default(true)
  bookingConfirmed  Boolean  @default(true)
  messageReceived   Boolean  @default(true)
  paymentReceipt    Boolean  @default(true)
  reviewReceived    Boolean  @default(true)
  system            Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PAID)
  subtotalAmount  Decimal
  discountAmount  Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  tipAmount       Decimal       @default(0)
  totalAmount     Decimal
  currency        String        @default("USD")
  receiptNumber   String        @unique
  cardBrand       String?
  cardLast4       String?
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointment     Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, paidAt])
  @@index([createdAt])
}

model AdPricing {
  placement       AdPlacement @id
  label           String
  dailyPrice      Decimal
  monthlyPrice    Decimal
  currency        String      @default("USD")
  note            String?
  updatedByUserId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  updatedBy       User?       @relation("AdPricingUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@index([updatedByUserId])
}

model PrivateTechnicianProfile {
  userId               String                         @id
  status               PrivateTechnicianProfileStatus @default(DRAFT)
  category             BusinessCategory               @default(NAIL)
  displayName          String
  headline             String?
  bio                  String?
  city                 String?
  state                String?
  postalCode           String?
  heroImage            String?
  featuredOnHomepage   Boolean                        @default(false)
  homepageRank         Int                            @default(999)
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  user                 User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  services             PrivateTechnicianService[]
  ads                  PrivateTechnicianAd[]

  @@index([category, status])
  @@index([status, featuredOnHomepage, homepageRank])
  @@index([city, state])
}

model PrivateTechnicianService {
  id              String                   @id @default(cuid())
  profileUserId   String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  profile         PrivateTechnicianProfile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  @@index([profileUserId, isActive])
}

model PrivateTechnicianAd {
  id              String                   @id @default(cuid())
  profileUserId   String
  campaignName    String
  placement       AdPlacement
  headline        String
  description     String?
  destinationUrl  String?
  budgetAmount    Decimal
  currency        String                   @default("USD")
  status          PrivateTechnicianAdStatus @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  profile         PrivateTechnicianProfile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  @@index([profileUserId, status, createdAt])
  @@index([placement, status])
}

model AdminAction {
  id          String   @id @default(cuid())
  adminUserId String
  targetType  String
  targetId    String
  action      String
  metadata    String?
  createdAt   DateTime @default(now())
  admin       User     @relation("AdminActor", fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
}

model BusinessCompliance {
  businessId             String   @id
  salonLicenseNumber     String
  businessLicenseNumber  String
  einNumber              String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  business               Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ProfessionalRegistration {
  userId              String                  @id
  accountType         ProfessionalAccountType @default(PRIVATE_TECHNICIAN)
  verificationStatus  VerificationStatus      @default(PENDING_REVIEW)
  identityCardNumber  String
  ssaNumber           String
  licenseNumber       String
  licenseState        String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountType, verificationStatus])
  @@map("TechnicianCredential")
}
